# Copy to /etc/sentinel/sentinel.env on the Raspberry Pi.
# Do not commit the real environment file.

HOST=127.0.0.1
PORT=8765
PYTHONPATH=/opt/sentinel/backend
SENTINEL_DB_PATH=/var/lib/sentinel/sentinel.sqlite3
SENTINEL_STATIC_DIR=/opt/sentinel/frontend
SENTINEL_LOG_FILE=/var/log/sentinel/sentinel.log

# Market data
MASSIVE_API_KEY=replace_with_massive_key

# Optional email alert delivery
SENTINEL_EMAIL_HOST=smtp.example.com
SENTINEL_EMAIL_PORT=587
SENTINEL_EMAIL_FROM=sentinel@example.com
SENTINEL_EMAIL_USERNAME=sentinel@example.com
SENTINEL_EMAIL_PASSWORD=replace_with_email_password
SENTINEL_EMAIL_TLS=1
SENTINEL_EMAIL_TIMEOUT_SECONDS=15

# Optional Telegram alert delivery
SENTINEL_TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
SENTINEL_TELEGRAM_TIMEOUT_SECONDS=15
